/*
 * nRF52840 DK overlay — enable I2C on Arduino header pins
 * SDA = P0.26 (Arduino A4/SDA)
 * SCL = P0.27 (Arduino A5/SCL)
 */
&arduino_i2c {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;   /* 100 kHz */

    max30102: max30102@57 {
        compatible = "maxim,max30101";
        reg = <0x57>;
        status = "okay";
    };
};
